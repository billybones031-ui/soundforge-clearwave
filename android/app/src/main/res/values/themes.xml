<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — Compose handles the real theming,
         this just keeps the system UI dark while the Compose tree loads. -->
    <style name="Theme.SoundForgeClearWave" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
